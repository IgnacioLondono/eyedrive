# Copia este archivo a .env y rellena los valores

# URL pública de la app
APP_URL=http://tu-servidor:9990

# Contraseña de PostgreSQL
POSTGRES_PASSWORD=cambia-esta-contraseña

# Correo SMTP (obligatorio para códigos de verificación en producción)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=contraseña-de-aplicacion
SMTP_FROM=Eyedrive <tu-correo@gmail.com>

# Duración de sesión en días
SESSION_DAYS=30
