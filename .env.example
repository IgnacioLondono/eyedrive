# Copia este archivo a .env y rellena los valores

# URL pública de la app
APP_URL=http://tu-servidor:9990

# Contraseña de PostgreSQL
POSTGRES_PASSWORD=cambia-esta-contraseña

# Correo con Resend (obligatorio para códigos de verificación en producción)
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Remitente verificado en Resend (dominio o email de prueba)
RESEND_FROM=Eyedrive <noreply@tu-dominio.com>

# Duración de sesión en días
SESSION_DAYS=30
